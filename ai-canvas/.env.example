# ============================================
# LOCAL DEVELOPMENT (npm run dev)
# ============================================
VITE_LIVEBLOCKS_KEY=pk_dev_your_liveblocks_key_here
VITE_WS_URL=ws://localhost:8000
VITE_API_URL=http://localhost:8000
VITE_ROOM_ID=hackathon-room
EXPRESS_PORT=3001

# ============================================
# VERCEL DEPLOYMENT
# ============================================
# 1. Deploy frontend to Vercel (static build)
# 2. Deploy Python + Express to Railway.app or Render.com (free tier)
# 3. Set these env vars in Vercel dashboard:

# VITE_LIVEBLOCKS_KEY=pk_dev_your_key
# VITE_WS_URL=wss://your-backend-name.railway.app    (or .onrender.com)
# VITE_API_URL=https://your-backend-name.railway.app  (or .onrender.com)
# VITE_ROOM_ID=hackathon-room
#
# Note: EXPRESS_PORT is only for local dev; Railway/Render assigns their own port
